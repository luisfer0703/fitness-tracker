# Copia a .env y rellena los valores

# Obligatorio en producción (Render → Environment)
SECRET_KEY=

# Carpeta de datos (local: data/ | Render: /opt/render/project/src/data)
DATA_DIR=

# Web Push — recordatorios (genera con: python scripts/generate_vapid.py)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_EMAIL=mailto:tu-email@ejemplo.com
